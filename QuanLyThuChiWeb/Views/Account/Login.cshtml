@{
    ViewData["Title"] = "Đăng nhập";
}

@if (TempData["RegisterSuccess"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-start border-success border-4 rounded-3" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill fs-4 me-3 text-success"></i>
                <div>
                    <strong class="fs-5">Đăng ký thành công!</strong>
                    <p class="mb-0 small">Tài khoản tài chính của bạn đã được khởi tạo vĩnh viễn trên hệ thống. Vui lòng đăng nhập bên dưới.</p>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
}

<div class="container" style="margin-top: 5rem; margin-bottom: 5rem;">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card shadow-lg border-0 rounded-4 p-4 p-sm-5 bg-white">

                <div class="text-center mb-4">
                    <div class="display-5 text-dark mb-2">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h3 class="fw-bold text-dark m-0">Đăng Nhập</h3>
                    <p class="text-muted small mt-1">Vui lòng đăng nhập để quản lý thu chi</p>
                </div>

                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-start border-danger border-4 rounded-3 small mb-3" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill fs-5 me-2 text-danger"></i>
                            <div>
                                @ViewBag.ErrorMessage
                            </div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form method="post" asp-controller="Account" asp-action="LoginProcess">

                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-secondary">Tài khoản hoặc Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-person"></i></span>
                            <input type="text" name="email" class="form-control bg-light border-start-0" placeholder="Username hoặc Email" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label class="form-label fw-semibold small text-secondary">Mật khẩu</label>
                            <a href="#" class="text-decoration-none small text-muted">Quên mật khẩu?</a>
                        </div>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-key"></i></span>
                            <input type="password" name="matKhau" class="form-control bg-light border-start-0" placeholder="••••••••" required />
                        </div>
                    </div>

                    <div class="form-check mb-4 small text-start">
                        <input class="form-check-input" type="checkbox" id="chkRememberMe">
                        <label class="form-check-label text-muted" for="chkRememberMe">
                            Duy trì đăng nhập trên thiết bị này
                        </label>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 rounded-pill py-2.5 fw-bold mb-3 shadow-sm">
                        Đăng nhập <i class="bi bi-arrow-right-short ms-1"></i>
                    </button>

                </form>

                <div class="text-center mt-3 border-top pt-3">
                    <span class="text-muted small">Chưa có tài khoản tài chính? </span>
                    <a asp-controller="Account" asp-action="Register" class="text-dark fw-bold small text-decoration-none">Đăng ký ngay</a>
                </div>

            </div>
        </div>
    </div>
</div>