@model IEnumerable<QuanLyThuChiWeb.Models.Transaction>

@{
    ViewData["Title"] = "Trang chủ - Quản lý thu chi";
}

<div class="container text-white" style="margin-top: 2rem;">
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-success text-white p-3 rounded-3 shadow-sm border-0">
                <small class="fw-semibold">Tổng thu</small>
                <h3 class="fw-bold m-0">@string.Format("{0:N0}", ViewBag.TongThu) đ</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger text-white p-3 rounded-3 shadow-sm border-0">
                <small class="fw-semibold">Tổng chi</small>
                <h3 class="fw-bold m-0">@string.Format("{0:N0}", ViewBag.TongChi) đ</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-primary text-white p-3 rounded-3 shadow-sm border-0">
                <small class="fw-semibold">Số dư</small>
                <h3 class="fw-bold m-0">@string.Format("{0:N0}", ViewBag.SoDu) đ</h3>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card bg-dark border-secondary p-4 rounded-3 shadow text-white">
                <h4 class="fw-bold mb-3">Ghi chép giao dịch</h4>

                <form method="post" asp-controller="Home" asp-action="ThemGiaoDich">

                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-secondary">$ Số tiền</label>
                        <input type="number" name="SoTien" class="form-control bg-dark border-secondary text-white" placeholder="Nhập số tiền" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-secondary">Loại giao dịch</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="LoaiGiaoDich" id="typeThu" value="Thu" required>
                                <label class="form-check-label" for="typeThu">Thu</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="LoaiGiaoDich" id="typeChi" value="Chi" checked>
                                <label class="form-check-label" for="typeChi">Chi</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-secondary">Danh mục</label>
                        <select name="DanhMuc" class="form-select bg-dark border-secondary text-white" required>
                            <option value="" disabled selected>Chọn danh mục</option>
                            <option value="Ăn uống">Ăn uống 🍔</option>
                            <option value="Tiền lương">Tiền lương 💵</option>
                            <option value="Mua sắm">Mua sắm 🛒</option>
                            <option value="Di chuyển">Di chuyển 🚗</option>
                            <option value="Học phí">Học phí 📚</option>
                            <option value="Khác">Khác ✨</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-secondary">Ngày và giờ</label>
                        <input type="datetime-local" name="NgayGiaoDich" class="form-control bg-dark border-secondary text-white" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-semibold text-secondary">Mô tả</label>
                        <textarea name="MoTa" class="form-control bg-dark border-secondary text-white" rows="2" placeholder="Nhập ghi chú giao dịch"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-light fw-bold flex-grow-1">Lưu</button>
                        <button type="reset" class="btn btn-outline-secondary text-white flex-grow-1">Hủy</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card bg-dark border-secondary p-4 rounded-3 shadow text-white h-100">
                <h4 class="fw-bold mb-3">Lịch sử giao dịch</h4>
                <div class="table-responsive">
                    <table class="table table-dark table-hover border-secondary align-middle m-0">
                        <thead>
                            <tr class="text-secondary small fw-semibold">
                                <th style="width: 20%">Ngày</th>
                                <th style="width: 15%">Loại</th>
                                <th style="width: 20%">Danh mục</th>
                                <th style="width: 20%">Số tiền</th>
                                <th style="width: 25%">Mô tả</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="small">@item.NgayGiaoDich.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            @if (item.LoaiGiaoDich == "Thu")
                                            {
                                                <span class="badge bg-success-subtle text-success px-2 py-1 rounded-2">Thu</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-subtle text-danger px-2 py-1 rounded-2">Chi</span>
                                            }
                                        </td>
                                        <td class="fw-semibold">@item.DanhMuc</td>
                                        <td class="@(item.LoaiGiaoDich == "Thu" ? "text-success" : "text-danger") fw-bold">
                                            @(item.LoaiGiaoDich == "Thu" ? "+" : "-") @string.Format("{0:N0}", item.SoTien) đ
                                        </td>
                                        <td class="text-muted small text-truncate" style="max-width: 150px;">@item.MoTa</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">Chưa có giao dịch nào được ghi nhận</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>